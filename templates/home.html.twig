{% extends 'layout.html.twig' %}

{% block title %}Kai — Find your people{% endblock %}

{% block content %}
<section class="hero">
    <div class="container">
        <h1 class="hero__headline">Find your people.<br>Build your community.</h1>
        <p class="hero__sub">Kai makes building your community easy. 100% free, no ads or tracking.</p>
        <div class="hero__actions">
            {% if current_user %}
                <a href="/dashboard" class="btn btn--primary btn--lg">Go to Dashboard</a>
            {% else %}
                <a href="/signup" class="btn btn--primary btn--lg">Get started &mdash; it&rsquo;s free</a>
                <a href="/signin" class="btn btn--ghost btn--lg">Sign in</a>
            {% endif %}
        </div>
    </div>
</section>

{% if exploreCity %}
<section class="explore-section">
    <div class="container">
        <div class="explore-section__header">
            <h2>Explore groups in your city</h2>
            <div id="city-widget" class="city-widget city-widget--has-value">
                <div class="city-widget__chosen">
                    <span>{{ exploreCity.name }}, {{ exploreCity.state }}</span>
                    <button type="button" class="btn btn--ghost btn--sm"
                            hx-get="/city-search?reset=1&mode=explore"
                            hx-target="#city-widget"
                            hx-swap="outerHTML">
                        Change
                    </button>
                </div>
            </div>
        </div>

        {% include 'partials/explore_groups_grid.html.twig' with {'groups': groups, 'oob': false} %}

        <div class="explore-section__footer">
            <a href="/groups" class="btn btn--ghost btn--sm">Browse all groups</a>
        </div>
    </div>
</section>
{% endif %}

<section class="how-it-works">
    <div class="container">
        <h2 class="section-title">How Kai works</h2>
        <ol class="steps">
            <li class="step">
                <span class="step__number">1</span>
                <h3>Create an account</h3>
                <p>Sign up in seconds. Completely free, no data collection or ads.</p>
            </li>
            <li class="step">
                <span class="step__number">2</span>
                <h3>Join groups</h3>
                <p>Discover groups in your city.</p>
            </li>
            <li class="step">
                <span class="step__number">3</span>
                <h3>Attend events</h3>
                <p>RSVP for meetups, workshops, and gatherings!</p>
            </li>
        </ol>
    </div>
</section>

<section class="features">
    <div class="container">
        <h2 class="section-title">Everything you need to connect</h2>
        <div class="feature-grid">
            <div class="feature-card">
                <div class="feature-card__icon" aria-hidden="true">&#128101;</div>
                <h3>Groups</h3>
                <p>Join or create groups in your city. Meet people who share your interests.</p>
            </div>
            <div class="feature-card">
                <div class="feature-card__icon" aria-hidden="true">&#128197;</div>
                <h3>Events</h3>
                <p>Browse upcoming events in your area. Online and in-person. One-offs and recurring.</p>
            </div>
            <div class="feature-card">
                <div class="feature-card__icon" aria-hidden="true">&#127758;</div>
                <h3>For the Community</h3>
                <p>Our focus is bringing people together in their communities, not making a profit.</p>
            </div>
        </div>
    </div>
</section>

<section class="cta-band">
    <div class="container">
        <h2>Ready to get started?</h2>
        <p>Join people around the country building real connections through Kai.</p>
        {% if current_user %}
            <a href="/dashboard" class="btn btn--primary btn--lg">Go to Dashboard</a>
        {% else %}
            <a href="/signup" class="btn btn--primary btn--lg">Create your free account</a>
        {% endif %}
    </div>
</section>
{% endblock %}
