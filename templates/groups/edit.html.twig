{% extends 'layout.html.twig' %}

{% block css %}<link rel="stylesheet" href="/css/pages/groups-form.css">{% endblock %}

{% block title %}Edit Group — Kai{% endblock %}

{% block content %}
<section class="form-page">
    <div class="container">
        <div class="form-card">
            <h1>Edit group</h1>
            <p class="form-card__sub"><a href="/groups/{{ group.slug }}">← Back to group</a></p>

            <form method="post" action="/groups/{{ group.slug }}/edit" novalidate>
                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

                <div class="form-group {% if errors.name is defined %}form-group--error{% endif %}">
                    <label for="name">Group name</label>
                    <input
                        type="text"
                        id="name"
                        name="name"
                        value="{{ old.name ?? '' }}"
                        maxlength="100"
                        required
                        {% if errors.name is defined %}aria-describedby="name-error"{% endif %}
                    >
                    {% if errors.name is defined %}
                        <span class="form-error" id="name-error">{{ errors.name }}</span>
                    {% endif %}
                </div>

                <div class="form-group {% if errors.description is defined %}form-group--error{% endif %}">
                    <label for="description">Description</label>
                    <textarea
                        id="description"
                        name="description"
                        maxlength="2000"
                        {% if errors.description is defined %}aria-describedby="description-error"{% endif %}
                    >{{ old.description ?? '' }}</textarea>
                    <span class="form-hint">Up to 2000 characters.</span>
                    {% if errors.description is defined %}
                        <span class="form-error" id="description-error">{{ errors.description }}</span>
                    {% endif %}
                </div>

                {% include 'partials/city_widget.html.twig' %}

                <div class="form-actions">
                    <button type="submit" class="btn btn--primary">Save changes</button>
                    <a href="/groups/{{ group.slug }}" class="btn btn--ghost">Cancel</a>
                </div>
            </form>

            <div class="form-section">
                <h2 class="form-section__heading">Links</h2>
                <p class="form-section__hint">Add external links to display on your group page.</p>
                {% include 'partials/group_links_edit.html.twig' with { 'group_slug': group.slug, 'links': links, 'errors': {}, 'old': {} } %}
            </div>
        </div>
    </div>
</section>
{% endblock %}
