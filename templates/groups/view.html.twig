{% extends 'layout.html.twig' %}

{% block title %}{{ group.name }} — Kai{% endblock %}

{% set page_description = group.description != '' ? group.description|striptags|slice(0, 160) : group.name ~ ' — a community group in ' ~ group.city_name ~ ', ' ~ group.city_state %}

{% block meta_description %}{{ page_description }}{% endblock %}

{% block og_title %}{{ group.name }} — Kai{% endblock %}
{% block og_description %}{{ page_description }}{% endblock %}

{% block twitter_title %}{{ group.name }} — Kai{% endblock %}
{% block twitter_description %}{{ page_description }}{% endblock %}

{% block canonical %}https://kaimeet.com/groups/{{ group.slug }}{% endblock %}

{% block content %}
<section class="group-detail">
    <div class="container">
        <div class="group-detail__layout">
        <div class="group-detail__card">
            <div class="group-detail__cover" style="background-size: 40px; background-image: url('{{ group_background(group.id) }}');" aria-hidden="true"></div>
            <div class="group-detail__body">
                <h1>{{ group.name }}</h1>
                <div class="group-detail__meta">
                    <span>{{ group.city_name }}, {{ group.city_state }}</span>
                    <span>{{ memberCount }} {{ memberCount == 1 ? 'member' : 'members' }}</span>
                    <span>Organized by {{ group.creator_name }}</span>
                </div>

                {% if group.description != '' %}
                    <p class="group-detail__description">{{ group.description|nl2br }}</p>
                {% endif %}

                {% if links is not empty %}
                    <div class="group-detail__links">
                        <ul class="group-links">
                            {% for link in links %}
                                <li class="group-links__item">
                                    <a href="{{ link.url }}" rel="noopener noreferrer nofollow" target="_blank">{{ link.title }}</a>
                                </li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endif %}

                <div class="group-detail__actions">
                    {% if current_user %}
                        {% if isMember and not isCreator %}
                            <form method="post" action="/groups/{{ group.slug }}/leave">
                                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                                <button type="submit" class="btn btn--ghost">Leave group</button>
                            </form>
                        {% endif %}
                        {% if not isMember %}
                            <form method="post" action="/groups/{{ group.slug }}/join">
                                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                                <button type="submit" class="btn btn--primary">Join group</button>
                            </form>
                        {% endif %}
                        {% if isCreator %}
                            <a href="/groups/{{ group.slug }}/edit" class="btn btn--ghost">Edit group</a>
                            <button type="submit" class="btn btn--danger" hx-delete="/groups/{{ group.slug }}/delete" hx-confirm="Are you sure you want to delete this event?">Delete group</button>
                        {% endif %}
                    {% else %}
                        <a href="/signin" class="btn btn--primary">Sign in to join</a>
                    {% endif %}
                </div>
            </div>
        </div>

        <aside class="group-detail__sidebar">
            <div class="sidebar-card">
                <h2 class="sidebar-card__title">Discussions</h2>
                <p class="sidebar-card__meta">{{ topicCount }} {{ topicCount == 1 ? 'topic' : 'topics' }}</p>
                <a href="/groups/{{ group.slug }}/discussions" class="btn btn--ghost btn--sm btn--full">View discussions</a>
            </div>
        </aside>

        <div class="group-events">
            <div class="group-events__header">
                <h2>Events</h2>
                <div class="group-events__header-actions">
                    <a href="/groups/{{ group.slug }}/feed.xml" class="btn btn--ghost btn--sm" title="Events RSS Feed">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16" aria-hidden="true">
                            <path d="M3.75 3a.75.75 0 0 0-.75.75v.5c0 .414.336.75.75.75H4c6.075 0 11 4.925 11 11v.25c0 .414.336.75.75.75h.5a.75.75 0 0 0 .75-.75V16C17 8.82 11.18 3 4 3h-.25Z" />
                            <path d="M3 8.75A.75.75 0 0 1 3.75 8H4a8 8 0 0 1 8 8v.25a.75.75 0 0 1-.75.75h-.5a.75.75 0 0 1-.75-.75V16a6 6 0 0 0-6-6h-.25A.75.75 0 0 1 3 9.25v-.5ZM7 15a2 2 0 1 1-4 0 2 2 0 0 1 4 0Z" />
                        </svg>
                        Events RSS Feed
                    </a>
                    {% if isCreator %}
                        <a href="/groups/{{ group.slug }}/events/create" class="btn btn--primary btn--sm">Create event</a>
                    {% endif %}
                </div>
            </div>

            {% if upcomingEvents is empty %}
                <div class="placeholder-card placeholder-card--empty">
                    <p>No upcoming events.{% if isCreator %} Create one to get started.{% endif %}</p>
                    {% if isCreator %}
                        <a href="/groups/{{ group.slug }}/events/create" class="btn btn--primary btn--sm">Create event</a>
                    {% endif %}
                </div>
            {% else %}
                <div class="event-list">
                    {% for ev in upcomingEvents %}
                        <article class="event-card">
                            <div class="event-card__datetime">
                                <span class="event-card__date">{{ (ev.event_date ~ ' ' ~ ev.event_time)|date('M j, Y') }}</span>
                                <span class="event-card__time">{{ (ev.event_date ~ ' ' ~ ev.event_time)|date('g:i A') }}</span>
                            </div>
                            <div class="event-card__body">
                                <h3 class="event-card__title">
                                    <a href="/groups/{{ group.slug }}/events/{{ ev.id }}">{{ ev.title }}</a>
                                </h3>
                                <p class="event-card__meta">
                                    {{ ev.rsvp_count }} going
                                    {% if ev.location != '' %}&middot; {{ ev.location }}{% endif %}
                                    {% if ev.meeting_url != '' %}&middot; Online{% endif %}
                                </p>
                            </div>
                            <div class="event-card__actions">
                                <a href="/groups/{{ group.slug }}/events/{{ ev.id }}">
                                    View
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                      <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
                                    </svg>
                                </a>
                                <span class="event-card__countdown">{{ event_countdown(ev.event_date, ev.event_time) }}</span>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}

            {% if pastCount > 0 %}
                <div id="past-events-section" class="group-events__past">
                    {% if showPast %}
                        {% include 'partials/past_events.html.twig' %}
                    {% else %}
                        <a href="/groups/{{ group.slug }}?show_past=1"
                           class="btn btn--ghost btn--sm"
                           hx-get="/groups/{{ group.slug }}/past-events"
                           hx-target="#past-events-section"
                           hx-swap="outerHTML">
                            Show past events ({{ pastCount }})
                        </a>
                    {% endif %}
                </div>
            {% endif %}
        </div>{# /.group-events #}

        </div>{# /.group-detail__layout #}
    </div>
</section>
{% endblock %}
