{% extends 'layout.html.twig' %}

{% block title %}Dashboard — Kai{% endblock %}

{% block content %}
<section class="dashboard">
    <div class="container">
        <div class="dashboard__header">
            <div>
                <h1 class="dashboard__greeting">Welcome back, {{ current_user.name }}!</h1>
                <p class="dashboard__date">{{ "now"|date("l, F j, Y") }}</p>
            </div>
        </div>

        <div class="dashboard__stats">
            <div class="stat-card">
                <span class="stat-card__value">{{ upcomingEvents|length }}</span>
                <span class="stat-card__label">Upcoming events</span>
            </div>
            <div class="stat-card">
                <span class="stat-card__value">{{ joinedGroups|length }}</span>
                <span class="stat-card__label">Groups joined</span>
            </div>
            <div class="stat-card">
                <span class="stat-card__value">0</span>
                <span class="stat-card__label">Events attended</span>
            </div>
        </div>
    </div>

    <div class="container">
        <section class="dashboard-section">
            <div class="dashboard-section__header">
                <h2>Your upcoming events</h2>
                <a href="/events" class="btn btn--ghost btn--sm">Browse events</a>
            </div>
            {% if upcomingEvents is empty %}
                <div class="placeholder-list">
                    <div class="placeholder-card placeholder-card--empty">
                        <p>You haven&rsquo;t RSVP&rsquo;d to any events yet.</p>
                        <a href="/groups" class="btn btn--primary btn--sm">Find events near you</a>
                    </div>
                </div>
            {% else %}
                <div class="event-list">
                    {% for ev in upcomingEvents %}
                        <article class="event-card">
                            <div class="event-card__datetime">
                                <span class="event-card__date">{{ (ev.event_date ~ ' ' ~ ev.event_time)|date('M j, Y') }}</span>
                                <span class="event-card__time">{{ (ev.event_date ~ ' ' ~ ev.event_time)|date('g:i A') }}</span>
                            </div>
                            <div class="event-card__body">
                                <h3 class="event-card__title">
                                    <a href="/groups/{{ ev.group_slug }}/events/{{ ev.id }}">{{ ev.title }}</a>
                                </h3>
                                <p class="event-card__meta">
                                    {{ ev.group_name }}
                                    {% if ev.location != '' %}&middot; {{ ev.location }}{% endif %}
                                    {% if ev.meeting_url != '' %}&middot; Online{% endif %}
                                </p>
                            </div>
                            <div class="event-card__actions">
                                <a href="/groups/{{ ev.group_slug }}/events/{{ ev.id }}">
                                    View
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                      <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
                                    </svg>
                                </a>
                                <span class="event-card__countdown">{{ event_countdown(ev.event_date, ev.event_time) }}</span>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}
        </section>

        <section class="dashboard-section">
            <div class="dashboard-section__header">
                <h2>Your groups</h2>
                <div class="dashboard-section__actions">
                    <a href="/groups/create" class="btn btn--ghost btn--sm">Start a group</a>
                    <a href="/groups" class="btn btn--ghost btn--sm">Explore groups</a>
                </div>
            </div>
            {% if joinedGroups is empty %}
                <div class="placeholder-card placeholder-card--empty">
                    <p>You haven&rsquo;t joined any groups yet.</p>
                    <a href="/groups" class="btn btn--primary btn--sm">Find groups</a>
                </div>
            {% else %}
                <div class="group-grid">
                    {% for group in joinedGroups %}
                        <article class="group-card">
                            <div class="group-card__cover" style="background-size: 40px; background-image: url('{{ group_background(group.id) }}');" aria-hidden="true"></div>
                            <div class="group-card__body">
                                <h3>{{ group.name }}</h3>
                                <p>{{ group.city_name }}, {{ group.city_state }} &middot; {{ group.member_count }} {{ group.member_count == 1 ? 'member' : 'members' }}</p>
                                <a href="/groups/{{ group.slug }}" class="btn btn--ghost btn--sm">View group</a>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}
        </section>

        {% if suggestedGroups is not empty %}
        <section class="dashboard-section">
            <div class="dashboard-section__header">
                <h2>Suggested for you</h2>
                <a href="/groups" class="btn btn--ghost btn--sm">Browse all</a>
            </div>
            <div class="group-grid">
                {% for group in suggestedGroups %}
                    <article class="group-card">
                        <div class="group-card__cover" style="background-size: 40px; background-image: url('{{ group_background(group.id) }}');" aria-hidden="true"></div>
                        <div class="group-card__body">
                            <h3>{{ group.name }}</h3>
                            <p>{{ group.city_name }}, {{ group.city_state }} &middot; {{ group.member_count }} {{ group.member_count == 1 ? 'member' : 'members' }}</p>
                            <a href="/groups/{{ group.slug }}" class="btn btn--ghost btn--sm">View group</a>
                        </div>
                    </article>
                {% endfor %}
            </div>
        </section>
        {% endif %}
    </div>
</section>
{% endblock %}
