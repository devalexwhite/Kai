<div id="past-events-section" class="group-events__past-list">
    <h3 class="group-events__past-heading">Past events</h3>
    {% if pastEvents is empty %}
        <p class="group-events__no-past">No past events.</p>
    {% else %}
        <div class="event-list">
            {% for ev in pastEvents %}
                <article class="event-card event-card--past">
                    <div class="event-card__datetime">
                        <span class="event-card__date">{{ (ev.event_date ~ ' ' ~ ev.event_time)|date('M j, Y') }}</span>
                        <span class="event-card__time">{{ (ev.event_date ~ ' ' ~ ev.event_time)|date('g:i A') }}</span>
                    </div>
                    <div class="event-card__body">
                        <h3 class="event-card__title">
                            <a href="/events/{{ ev.id }}">{{ ev.title }}</a>
                        </h3>
                        <p class="event-card__meta">
                            {{ ev.rsvp_count }} {{ ev.rsvp_count == 1 ? 'attendee' : 'attendees' }}
                            {% if ev.location != '' %}&middot; {{ ev.location }}{% endif %}
                            {% if ev.meeting_url != '' %}&middot; Online{% endif %}
                        </p>
                    </div>
                </article>
            {% endfor %}
        </div>
    {% endif %}
</div>
