<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Kai - Find Your People{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}Kai helps you find and connect with your people. Join groups, discover events, and build meaningful communities in your city.{% endblock %}">
    <meta name="keywords" content="community, groups, events, social network, find people, local connections">
    <meta name="author" content="Kai">
    <meta property="og:title" content="{% block og_title %}Kai - Find Your People{% endblock %}">
    <meta property="og:description" content="{% block og_description %}Kai helps you find and connect with your people. Join groups, discover events, and build meaningful communities in your city.{% endblock %}">
    <meta property="og:type" content="website">
    <meta property="og:image" content="{% block og_image %}/images/meta.png{% endblock %}">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{% block twitter_title %}Kai - Find Your People{% endblock %}">
    <meta name="twitter:description" content="{% block twitter_description %}Kai helps you find and connect with your people. Join groups, discover events, and build meaningful communities in your city.{% endblock %}">
    <meta name="twitter:image" content="{% block twitter_image %}/images/meta.png{% endblock %}">
    <link rel="canonical" href="{% block canonical %}https://kaimeet.com{% endblock %}">
    <link rel="icon" href="/images/icons/favicon.ico" sizes="any">
    <link rel="shortcut icon" href="/images/icons/favicon.ico">
    <link rel="icon" type="image/png" sizes="16x16" href="/images/icons/icon-16x16.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/images/icons/icon-32x32.png">
    <link rel="icon" type="image/png" sizes="48x48" href="/images/icons/icon-48x48.png">
    <link rel="icon" type="image/png" sizes="64x64" href="/images/icons/icon-64x64.png">
    <link rel="icon" type="image/png" sizes="128x128" href="/images/icons/icon-128x128.png">
    <link rel="icon" type="image/png" sizes="256x256" href="/images/icons/icon-256x256.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/images/icons/icon-180x180.png">
    <meta name="msapplication-square70x70logo" content="/images/icons/icon-70x70.png">
    <meta name="msapplication-square150x150logo" content="/images/icons/icon-150x150.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho+B1:wght@400;600;800&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/base.css">
    {% block css %}{% endblock %}

</head>
{# hx-headers sends the CSRF token with every HTMX request automatically #}
<body hx-headers='{"X-CSRF-Token": "{{ csrf_token }}"}'>

    {% include 'partials/nav.html.twig' %}

    {% set flash_messages = flash.getMessages() %}
    {% for type in ['success', 'error', 'info'] %}
        {% for msg in (flash_messages[type] ?? []) %}
            <div class="flash flash--{{ type }}" role="alert">{{ msg }}</div>
        {% endfor %}
    {% endfor %}

    <main>
        {% block content %}{% endblock %}
    </main>

    <footer class="site-footer">
        <div class="container">
            <p>&copy; {{ "now"|date("Y") }} Kai &mdash; Find your people.</p>
            <div class="site-footer__actions">
                <a href="https://github.com/devalexwhite/Kai" target="_blank">View Source</a>
                <a href="/privacy-policy" target="_blank">Privacy Policy</a>
                <a href="https://buymeacoffee.com/devalexwhite">Support Kai</a>
            </div>
        </div>
    </footer>

    <script src="/htmx.min.js"></script>
</body>
</html>
