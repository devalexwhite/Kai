{% extends 'layout.html.twig' %}

{% block css %}<link rel="stylesheet" href="/css/pages/events-browse.css">{% endblock %}

{% block title %}Browse Events — Kai{% endblock %}

{% block content %}
<section class="browse-events">
    <div class="container">
        <div class="browse-events__header">
            <h1>Browse events</h1>
        </div>

        {% if not current_user %}
            <div class="placeholder-card placeholder-card--empty">
                <p>Sign in to browse events near you.</p>
                <a href="/signin" class="btn btn--primary btn--sm">Sign in</a>
            </div>
        {% else %}

            {% if myRsvpdEvents is not empty %}
            <section class="dashboard-section">
                <div class="dashboard-section__header">
                    <h2>Your upcoming events</h2>
                </div>
                <div class="event-list">
                    {% for ev in myRsvpdEvents %}
                        <article class="event-card">
                            <div class="event-card__datetime">
                                <span class="event-card__date">{{ (ev.event_date ~ ' ' ~ ev.event_time)|date('M j, Y') }}</span>
                                <span class="event-card__time">{{ (ev.event_date ~ ' ' ~ ev.event_time)|date('g:i A') }}</span>
                            </div>
                            <div class="event-card__body">
                                <h3 class="event-card__title">
                                    <a href="/groups/{{ ev.group_slug }}/events/{{ ev.id }}">{{ ev.title }}</a>
                                </h3>
                                <p class="event-card__meta">
                                    <a href="/groups/{{ ev.group_slug }}">{{ ev.group_name }}</a>
                                    {% if ev.location != '' %}&middot; {{ ev.location }}{% endif %}
                                    {% if ev.meeting_url != '' %}&middot; Online{% endif %}
                                </p>
                            </div>
                            <span class="event-card__countdown">{{ event_countdown(ev.event_date, ev.event_time) }}</span>
                        </article>
                    {% endfor %}
                </div>
            </section>
            {% endif %}

            {% if myGroupEvents is not empty %}
            <section class="dashboard-section">
                <div class="dashboard-section__header">
                    <h2>From your groups</h2>
                </div>
                <div class="event-list">
                    {% for ev in myGroupEvents %}
                        <article class="event-card">
                            <div class="event-card__datetime">
                                <span class="event-card__date">{{ (ev.event_date ~ ' ' ~ ev.event_time)|date('M j, Y') }}</span>
                                <span class="event-card__time">{{ (ev.event_date ~ ' ' ~ ev.event_time)|date('g:i A') }}</span>
                            </div>
                            <div class="event-card__body">
                                <h3 class="event-card__title">
                                    <a href="/groups/{{ ev.group_slug }}/events/{{ ev.id }}">{{ ev.title }}</a>
                                </h3>
                                <p class="event-card__meta">
                                    <a href="/groups/{{ ev.group_slug }}">{{ ev.group_name }}</a>
                                    {% if ev.location != '' %}&middot; {{ ev.location }}{% endif %}
                                    {% if ev.meeting_url != '' %}&middot; Online{% endif %}
                                </p>
                            </div>
                            <span class="event-card__countdown">{{ event_countdown(ev.event_date, ev.event_time) }}</span>
                        </article>
                    {% endfor %}
                </div>
            </section>
            {% endif %}

            {% if cityEvents is not empty %}
            <section class="dashboard-section">
                <div class="dashboard-section__header">
                    <h2>More events near you</h2>
                </div>
                <div class="event-list">
                    {% for ev in cityEvents %}
                        <article class="event-card">
                            <div class="event-card__datetime">
                                <span class="event-card__date">{{ (ev.event_date ~ ' ' ~ ev.event_time)|date('M j, Y') }}</span>
                                <span class="event-card__time">{{ (ev.event_date ~ ' ' ~ ev.event_time)|date('g:i A') }}</span>
                            </div>
                            <div class="event-card__body">
                                <h3 class="event-card__title">
                                    <a href="/groups/{{ ev.group_slug }}/events/{{ ev.id }}">{{ ev.title }}</a>
                                </h3>
                                <p class="event-card__meta">
                                    <a href="/groups/{{ ev.group_slug }}">{{ ev.group_name }}</a>
                                    {% if ev.location != '' %}&middot; {{ ev.location }}{% endif %}
                                    {% if ev.meeting_url != '' %}&middot; Online{% endif %}
                                </p>
                            </div>
                            <span class="event-card__countdown">{{ event_countdown(ev.event_date, ev.event_time) }}</span>
                        </article>
                    {% endfor %}
                </div>
            </section>
            {% endif %}

            {% if myRsvpdEvents is empty and myGroupEvents is empty and cityEvents is empty %}
                <div class="placeholder-card placeholder-card--empty">
                    <p>No upcoming events found. Join some groups to discover events near you.</p>
                    <a href="/groups" class="btn btn--primary btn--sm">Browse groups</a>
                </div>
            {% endif %}

        {% endif %}
    </div>
</section>
{% endblock %}
