{% extends 'layout.html.twig' %}

{% block css %}<link rel="stylesheet" href="/css/pages/events-form.css">{% endblock %}

{% block title %}Edit Event — Kai{% endblock %}

{% block content %}
<section class="form-page">
    <div class="container">
        <div class="form-card">
            <h1>Edit event</h1>
            <p class="form-card__sub"><a href="/groups/{{ event.group_slug }}/events/{{ event.id }}">← Back to event</a></p>

            <form method="post" action="/groups/{{ event.group_slug }}/events/{{ event.id }}/edit" novalidate>
                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

                <div class="form-group {% if errors.title is defined %}form-group--error{% endif %}">
                    <label for="title">Event title</label>
                    <input
                        type="text"
                        id="title"
                        name="title"
                        value="{{ old.title ?? '' }}"
                        maxlength="120"
                        required
                        {% if errors.title is defined %}aria-describedby="title-error"{% endif %}
                    >
                    {% if errors.title is defined %}
                        <span class="form-error" id="title-error">{{ errors.title }}</span>
                    {% endif %}
                </div>

                <div class="form-group {% if errors.description is defined %}form-group--error{% endif %}">
                    <label for="description">Description</label>
                    <textarea
                        id="description"
                        name="description"
                        maxlength="2000"
                        {% if errors.description is defined %}aria-describedby="description-error"{% endif %}
                    >{{ old.description ?? '' }}</textarea>
                    <span class="form-hint">Up to 2000 characters.</span>
                    {% if errors.description is defined %}
                        <span class="form-error" id="description-error">{{ errors.description }}</span>
                    {% endif %}
                </div>

                <div class="form-row">
                    <div class="form-group {% if errors.event_date is defined %}form-group--error{% endif %}">
                        <label for="event_date">Date</label>
                        <input
                            type="date"
                            id="event_date"
                            name="event_date"
                            value="{{ old.event_date ?? '' }}"
                            required
                            {% if errors.event_date is defined %}aria-describedby="event_date-error"{% endif %}
                        >
                        {% if errors.event_date is defined %}
                            <span class="form-error" id="event_date-error">{{ errors.event_date }}</span>
                        {% endif %}
                    </div>

                    <div class="form-group {% if errors.event_time is defined %}form-group--error{% endif %}">
                        <label for="event_time">Time</label>
                        <input
                            type="time"
                            id="event_time"
                            name="event_time"
                            value="{{ old.event_time ?? '' }}"
                            required
                            {% if errors.event_time is defined %}aria-describedby="event_time-error"{% endif %}
                        >
                        {% if errors.event_time is defined %}
                            <span class="form-error" id="event_time-error">{{ errors.event_time }}</span>
                        {% endif %}
                    </div>
                </div>

                <div class="form-group {% if errors.location is defined %}form-group--error{% endif %}">
                    <label for="location">Location <span class="form-hint">(in-person venue — optional)</span></label>
                    <input
                        type="text"
                        id="location"
                        name="location"
                        value="{{ old.location ?? '' }}"
                        maxlength="200"
                        placeholder="e.g. Central Park, New York"
                        {% if errors.location is defined %}aria-describedby="location-error"{% endif %}
                    >
                    {% if errors.location is defined %}
                        <span class="form-error" id="location-error">{{ errors.location }}</span>
                    {% endif %}
                </div>

                <div class="form-group {% if errors.meeting_url is defined %}form-group--error{% endif %}">
                    <label for="meeting_url">Meeting URL <span class="form-hint">(remote link — optional)</span></label>
                    <input
                        type="url"
                        id="meeting_url"
                        name="meeting_url"
                        value="{{ old.meeting_url ?? '' }}"
                        maxlength="500"
                        placeholder="https://..."
                        {% if errors.meeting_url is defined %}aria-describedby="meeting_url-error"{% endif %}
                    >
                    {% if errors.meeting_url is defined %}
                        <span class="form-error" id="meeting_url-error">{{ errors.meeting_url }}</span>
                    {% endif %}
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn--primary">Save changes</button>
                    <a href="/groups/{{ event.group_slug }}/events/{{ event.id }}" class="btn btn--ghost">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</section>
{% endblock %}
